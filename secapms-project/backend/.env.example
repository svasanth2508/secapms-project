# Copy this file to .env and fill in real values before running the backend.
# Never commit the real .env file.

# ---------- Supabase ----------
# Project Settings -> API in your Supabase/Lovable Cloud dashboard.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the SERVICE ROLE key here (not the anon/publishable key) - this bridge
# runs server-side and must bypass RLS to write device data on behalf of
# hardware that has no Supabase Auth session of its own.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ---------- MQTT broker ----------
# Must match the broker your ESP32 devices are configured to use in
# firmware/common/secapms_config.h.
MQTT_URL=mqtts://YOUR_BROKER_HOST:8883
MQTT_USERNAME=secapms_backend
MQTT_PASSWORD=change_me
MQTT_TOPIC_PREFIX=secapms/v1

# ---------- HTTP health check ----------
PORT=8080
